<Controls:MetroWindow  x:Class="ViertelStdTool.Views.UserInfoEmergencySoftware"  x:Name="ViertelStdTool"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"                     
                       xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro" 
                       xmlns:local="clr-namespace:ViertelStdTool.Views"
                       mc:Ignorable="d"
                       Title="This software should only be used if standard tool fails !"
                       Height="150" 
                       Width="500"
                       ShowIconOnTitleBar ="True"
                       ShowCloseButton="False"
                       ShowTitleBar="True"
                       Icon="../quarterHour.ico"
                       TitleCaps="False"
                       WindowStartupLocation="CenterScreen" 
                       ResizeMode="NoResize"
                       BorderThickness="2">
    <Grid>
        <Button x:Name="UseTool" Content="accepted --> use the tool" Margin="260,50,25,25" Click="UseTool_Click" Style="{DynamicResource SquareButtonStyle}" HorizontalAlignment="Left" Width="190" Height="40" VerticalAlignment="Top" Background="Red"/>
        <Button x:Name="DoNotUseTool" Content="not accepted --> close the tool" Margin="35,50,25,25" Click="CloseTool_Click" Style="{DynamicResource SquareButtonStyle}" HorizontalAlignment="Left" Width="190" Height="40" VerticalAlignment="Top" Background="Green"/>
    </Grid>
 </Controls:MetroWindow>
