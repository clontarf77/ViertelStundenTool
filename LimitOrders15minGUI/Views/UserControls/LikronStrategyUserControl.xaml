<UserControl x:Class="ViertelStdTool.Views.Controls.LikronStrategyUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ViertelStdTool.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Label x:Name="LikronStrategyLabel" Content="Likron Strategy" Margin="25,0,0,0" FontSize="15" FontWeight="Thin" Height="265" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300"/>
        <Label x:Name="LikronStrategy" Content="GFS (Not from Load-File)" Margin="25,25,0,0" FontSize="15" FontWeight="SemiBold" Height="265" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300"/>
        <Label x:Name="LikronValidityEndLabel" Content="Likron Validity End" Margin="25,75,0,0" FontSize="15" FontWeight="Thin" Height="265" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300"/>
        <Label x:Name="LikronEndValidity" Content="Empty (Not fromLoad-File)" Margin="25,100,0,0" FontSize="15" FontWeight="SemiBold" Height="265" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300"/>
    </Grid>
</UserControl>
