<Controls:MetroWindow x:Class="LimitOrders15minGUI.Views.AppView" x:Name="LimitOrders15minGUI"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"                     
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro" 
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
                      xmlns:uc="clr-namespace:ViertelStdTool.Views.Controls"
                      mc:Ignorable="d"                    
                      Title= "{Binding AppModel.WindowTitle}"                      
                      Height="531" 
                      Width="1300"
                      ShowIconOnTitleBar ="True"
                      ShowTitleBar="True"                        
                      TitleCaps="False"
                      ResizeMode="NORESIZE"
                      WindowStartupLocation="CenterScreen"
                      BorderThickness="2" 
                      Closing="AppView_Closing" 
                      Icon="../quarterHour.ico">

    <!-- Buttons windows title -->
    <Controls:MetroWindow.RightWindowCommands>
        <Controls:WindowCommands>
            <ToggleButton IsChecked="{Binding ElementName=UserInfo, Path=IsOpen}" Cursor="Hand" ToolTip="UserInfo" ToolTipService.ShowDuration="5000">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern Width="20" Height="20" Kind="User" />
                </StackPanel>
            </ToggleButton>
            <!--<ToggleButton IsChecked="{Binding ElementName=SettingsAligneBooking, Path=IsOpen}" Cursor="Hand" ToolTip="SettingsAligneBooking" ToolTipService.ShowDuration="5000">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern Width="20" Height="20" Kind="Settings" />
                </StackPanel>
            </ToggleButton>-->
            <ToggleButton IsChecked="{Binding ElementName=ErrorMailSetting, Path=IsOpen}" Cursor="Hand" ToolTip="ErrorMailSetting" ToolTipService.ShowDuration="5000">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern Width="20" Height="20" Kind="Email"/>
                </StackPanel>
            </ToggleButton>
            <ToggleButton IsChecked="{Binding ElementName=LikronStrategy, Path=IsOpen}" Cursor="Hand" ToolTip="LikronStrategy" ToolTipService.ShowDuration="5000">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern Width="20" Height="20" Kind="Money"/>
                </StackPanel>
            </ToggleButton>
        </Controls:WindowCommands>
    </Controls:MetroWindow.RightWindowCommands>

    <!-- Flyouts -->
    <Controls:MetroWindow.Flyouts>
        <Controls:FlyoutsControl>
            <Controls:Flyout x:Name="UserInfo" Header="UserInfo" Position="Right" Width="350" IsOpen="False">
                <uc:UserInfoUserControl x:Name="UCUserInfo" Margin="40,40,85,0"/>
            </Controls:Flyout>
            <!--<Controls:Flyout x:Name="SettingsAligneBooking" Header="Booking / Order Generation" Position="Right" Width="350" IsOpen="False">
                <uc:SettingsAligneBookingUserControl x:Name="UCSettingsAligneBooking" Margin="40,40,85,0"/>
            </Controls:Flyout>-->
            <Controls:Flyout x:Name="ErrorMailSetting" Header="Settings Error Mail" Position="Right" Width="350" IsOpen="False">
                <uc:ErrorMailSettingsUserControl x:Name="UCErrorMailSetting" Margin="40,40,85,0"/>
            </Controls:Flyout>
            <Controls:Flyout x:Name="LikronStrategy" Header="Settings Likron" Position="Right" Width="350" IsOpen="False">
                <uc:LikronStrategyUserControl x:Name="UCLikronStrategy" Margin="40,40,85,0"/>
            </Controls:Flyout>
        </Controls:FlyoutsControl>
    </Controls:MetroWindow.Flyouts>

    <!-- Main-Region -->
    <Controls:MetroContentControl>
        <Grid Background="#FFE5E5E5">
            <Button x:Name="StartApplication" Content="start" Margin="0,0,20,20" HorizontalAlignment="Right" Width="160" Height="52" VerticalAlignment="Bottom" Click ="StartApplication_Click" Background="LimeGreen" FontSize="18"/>
            <Button x:Name="StopApplication" Content="stop" Margin="0,0,20,20" HorizontalAlignment="Right" Width="160" Height="52" VerticalAlignment="Bottom" Click ="StopApplication_Click" Foreground="White" Background="Red" FontSize="18" Visibility="Hidden"/>
            <Label x:Name="LabelControlArea" Content="Control Area" HorizontalAlignment="Left" Margin="1008,275,0,0" VerticalAlignment="Top" Width="140" FontSize="20"/>
            <Label x:Name="AppStatus" Content="{Binding AppModel.AppStatus, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Margin="1008,0,0,405" FontSize="30" HorizontalAlignment="Left" Width="200" Height="79" VerticalAlignment="Bottom" Foreground="red"/>
            <Label x:Name="LabelDate" Content="LabelDate" Margin="955,420,0,0" FontSize="15" HorizontalAlignment="Left" Width="154" Height="30" VerticalAlignment="Top"/>
            <Label x:Name="LabelTime" Content="LabelTime" Margin="955,432,0,19" FontSize="30" HorizontalAlignment="Left" Width="154"/>
            <Label x:Name="LabelLoadLimit" Content="Current Load Limit" Margin="1008,78,0,0" FontSize="15" HorizontalAlignment="Left" Width="140" Height="30" VerticalAlignment="Top"/>
            <Label x:Name="LabelLoadSetLimit" Content="{Binding AppModel.SetLoadLimit, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Margin="1008,90,0,360" FontSize="30" HorizontalAlignment="Left" Width="250"/>
            <Label x:Name="LabelSellLimit" Content="Current Sell Limit" Margin="1008,138,0,0" FontSize="15" HorizontalAlignment="Left" Width="140" Height="30" VerticalAlignment="Top"/>
            <Label x:Name="LabelSellSetLimit" Content="{Binding AppModel.SetSellLimit, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Margin="1008,150,0,300" FontSize="30" HorizontalAlignment="Left" Width="250"/>
            <Label x:Name="LabelBuyLimit" Content="Current Buy Limit" Margin="1008,198,0,0" FontSize="15" HorizontalAlignment="Left" Width="140" Height="30" VerticalAlignment="Top"/>
            <Label x:Name="LabelBuySetLimit" Content="{Binding AppModel.SetBuyLimit, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Margin="1008,210,0,240" FontSize="30" HorizontalAlignment="Left" Width="250"/>
            <ComboBox x:Name="ComboBox_Area" ItemsSource= "{Binding AppModel.ControlAreaList}" SelectedItem= "{Binding AppModel.SelectedArea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedIndex="0" Margin="1140,282,0,0" HorizontalAlignment="Left" Width="135" Height="26" VerticalAlignment="Top" IsEnabled="False"/>
            <Label x:Name="LabelNumberReadTradesFromLikron" Content="Number booked trades from Likron:" HorizontalAlignment="Left" Margin="10,312,0,0" VerticalAlignment="Top" Width="400" FontSize="16" Visibility="Hidden" Foreground="Black" FontWeight="DemiBold"/>
            <Label x:Name="NumberOfReadTradesFromLikron" Content="{Binding AppModel.NumberBookedTradesFromLikron, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="285,312,0,0" VerticalAlignment="Top" Width="550" FontSize="16" Foreground="gray" FontStyle="Italic" Visibility="Hidden"/>
            <Label x:Name="LabelNumberBookedTradesToAligne" Content="Number booked trades to Aligne:" HorizontalAlignment="Left" Margin="10,312,0,0" VerticalAlignment="Top" Width="400" FontSize="16" Visibility="Hidden" Foreground="Black" FontWeight="DemiBold"/>
            <Label x:Name="NumberOfBookedTradesToAligne" Content="{Binding AppModel.NumberBookedTradesToAligne, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="285,312,0,0" VerticalAlignment="Top" Width="550" FontSize="16" Foreground="gray" FontStyle="Italic" Visibility="Hidden"/>
            <Label x:Name="LabelLastExecutionTime" Content="Latest excecution:" HorizontalAlignment="Left" Margin="10,340,0,0" VerticalAlignment="Top" Width="400" FontSize="16"  Foreground="Black" FontWeight="DemiBold"/>
            <Label x:Name="LabelCountdownOrderThread" Content="" Margin="1008,330,0,0" FontSize="22" HorizontalAlignment="Left" Width="262" Height="47" VerticalAlignment="Top" Visibility="Hidden" Foreground="blue"/>
            <Label x:Name="LabelCountdownBookingThread" Content="" Margin="1008,370,0,0" FontSize="22" HorizontalAlignment="Left" Width="262" Height="47" VerticalAlignment="Top" Visibility="Hidden" Foreground="blue"/>
            <Label x:Name="LastExecutionTime" Content="{Binding AppModel.LastExecutionTime, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="285,340,0,0" VerticalAlignment="Top" Width="400" FontSize="16" Foreground="gray" FontStyle="Italic"/>
            <Label x:Name="LabelLastExecutionTimeWithNewLoadFile" Content="Latest excecution with new load file:" HorizontalAlignment="Left" Margin="10,370,0,0" VerticalAlignment="Top" Width="400" FontSize="16" Foreground="Black" FontWeight="DemiBold"/>
            <Label x:Name="LastExecutionTimeWithNewLoadFile" Content="{Binding AppModel.LastExecutionTimeWithNewLoadFile, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="285,370,0,0" VerticalAlignment="Top" Width="400" FontSize="16" Foreground="gray" FontStyle="Italic"/>
            <Label x:Name="LabelNameOfLatestLoadFile" Content="Name of latest read load file:" HorizontalAlignment="Left" Margin="10,400,0,0" VerticalAlignment="Top" Width="400" FontSize="16"  Foreground="Black" FontWeight="DemiBold"/>
            <Label x:Name="NameOfLatestLoadFile" Content="{Binding AppModel.NameLatestLoadFile, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="285,400,0,0" VerticalAlignment="Top" Width="400" FontSize="16" Foreground="gray" FontStyle="Italic"/>
            <Label x:Name="LabelNameOfLatestLikronFile" Content="Name of latest order file(s) for likron:" HorizontalAlignment="Left" Margin="10,430,0,0" VerticalAlignment="Top" Width="400" FontSize="16" Foreground="Black" FontWeight="DemiBold"/>
            <Label x:Name="NameOfLatestLikronFile" Content="{Binding AppModel.NameLatestGeneratedFile, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="285,430,0,0" VerticalAlignment="Top" Width="650" FontSize="16" Foreground="gray" FontStyle="Italic"/>
            <Label x:Name="ErrorDescription" Foreground="Red" Content="{Binding AppModel.ErrorDescription, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="10,457,0,0" VerticalAlignment="Top" Width="600" FontSize="16" />
            <Label x:Name="ContractRange" Foreground ="Blue" Content="{Binding AppModel.ContractRange, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Margin="850,9,0,0" VerticalAlignment="Top" Width="600" FontSize="20" FontWeight="DemiBold"/>
            <TabControl SelectionChanged="TabControl_SelectionChanged" HorizontalAlignment="Left" Height="300" Margin="5,10,0,0" VerticalAlignment="Top" Width="950">
                <TabItem x:Name="Tab_LoadData" Header="LoadData">
                    <Grid Background="#FFE5E5E5">
                        <DataGrid Margin="0,0,0,0" ItemsSource="{Binding AppModel.ViewLoadData, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" CanUserAddRows="False" CanUserResizeColumns="False" CanUserDeleteRows="False" IsReadOnly="True"/>
                    </Grid>
                </TabItem>
                <TabItem x:Name="Tab_LimitData" Header="LimitData">
                    <Grid Background="#FFE5E5E5">
                        <DataGrid Margin="0,0,0,0" ItemsSource="{Binding AppModel.ViewLimitData, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" CanUserAddRows="False" CanUserResizeColumns="False" CanUserDeleteRows="False" IsReadOnly="True"/>
                    </Grid>
                </TabItem>
                <TabItem x:Name="Tab_OrderData" Header="OrderData">
                    <Grid Background="#FFE5E5E5">
                        <DataGrid Margin="0,0,0,0" ItemsSource="{Binding AppModel.ViewLikronData, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" CanUserAddRows="False" CanUserResizeColumns="False" CanUserDeleteRows="False" IsReadOnly="True"/>
                    </Grid>
                </TabItem>
                <TabItem x:Name="Tab_ExecutedTradesLikron" Header="ExecutedLikron">
                    <Grid Background="#FFE5E5E5">
                        <DataGrid Margin="0,0,0,0" ItemsSource="{Binding AppModel.ViewBookedTradesFromLikron, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" CanUserAddRows="False" CanUserResizeColumns="False" CanUserDeleteRows="False" IsReadOnly="True"/>
                    </Grid>
                </TabItem>
                <TabItem x:Name="Tab_BookedTradesAligne" Header="BookedAligne">
                    <Grid Background="#FFE5E5E5">
                        <DataGrid Margin="0,0,0,0" ItemsSource="{Binding AppModel.ViewBookedTradesToAligne, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" CanUserAddRows="False" CanUserResizeColumns="False" CanUserDeleteRows="False" IsReadOnly="True"/>
                    </Grid>
                </TabItem>
                <TabItem x:Name="Tab_Limits" Header="Limits">
                    <Grid Background="#FFE5E5E5">
                        <Label x:Name="Label_Quanitity_in" Content="Load Limit in" HorizontalAlignment="Left" Margin="20,30,0,0" VerticalAlignment="Top" Width="130" FontSize="20"/>
                        <ComboBox x:Name="ComboBox_LimitType" ItemsSource= "{Binding AppModel.LimitTypeList}" SelectedItem= "{Binding AppModel.SelectedLimitType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedIndex="0" Margin="160,36,0,0" SelectionChanged="ComboBox_LimitType_Changed" HorizontalAlignment="Left" Width="130" Height="26" VerticalAlignment="Top"/>
                        <TextBlock x:Name="Quanitity_in_MWh" Text="Load Limit in MWh" TextWrapping="Wrap" HorizontalAlignment="Left" Margin="25,80,0,0" VerticalAlignment="Top" Width="113" Height="100" FontSize="20" Visibility="Hidden"/>
                        <TextBlock x:Name="Quanitity_in_Percent" Text="Load Limit in percent" TextWrapping="Wrap" HorizontalAlignment="Left" Margin="25,80,0,0" VerticalAlignment="Top" Width="113" FontSize="20" Visibility="Hidden"/>
                        <TextBox x:Name="TextBox_LoadLimit" HorizontalAlignment="Left" Height="23" Margin="160,96,0,0" TextWrapping="Wrap" TextChanged="ValueLoadLimitEntered_TextChanged" Text="" VerticalAlignment="Top" Width="130" Visibility="Hidden"/>
                        <Button x:Name="SkipLoadLimit" Content="remove load limit" Click ="SkipLoadLimit_Click" FontSize="18" Margin="20,0,0,30" HorizontalAlignment="Left" Width="160" Height="50" VerticalAlignment="Bottom" Visibility="Hidden"/>
                        <Button x:Name="SetLoadLimit" Content="set load limit" Margin="20,0,0,30" Click="SetLoadLimit_Click" FontSize="18" Visibility="Hidden" HorizontalAlignment="Left" Width="160" Height="52" VerticalAlignment="Bottom"/>
                        <TextBlock x:Name="SellLimitEuro" Text="Sell Limit in Euro" TextWrapping="Wrap" HorizontalAlignment="Left" Margin="350,80,0,0" VerticalAlignment="Top" Width="100" FontSize="20" Visibility="Visible"/>
                        <TextBox x:Name="TextBox_SellLimit" HorizontalAlignment="Left" Height="23" Margin="460,96,0,0" TextWrapping="Wrap" TextChanged="ValueSellLimitEntered_TextChanged" Text="" VerticalAlignment="Top" Width="130" Visibility="Visible"/>
                        <Button x:Name="SkipSellLimit" Content="remove sell limit" Click ="SkipSellLimit_Click" FontSize="18" Margin="460,0,0,30" HorizontalAlignment="Left" Width="160" Height="50" VerticalAlignment="Bottom" Visibility="Hidden"/>
                        <Button x:Name="SetSellLimit" Content="set sell limit" Margin="460,0,0,29" Click="SetSellLimit_Click" FontSize="18" Visibility="Hidden" HorizontalAlignment="Left" Width="160" Height="52" VerticalAlignment="Bottom"/>
                        <TextBlock x:Name="BuyLimitEuro" Text="Buy Limit in Euro" TextWrapping="Wrap" HorizontalAlignment="Left" Margin="650,80,0,0" VerticalAlignment="Top" Width="100" FontSize="20" Visibility="Visible"/>
                        <TextBox x:Name="TextBox_BuyLimit" HorizontalAlignment="Left" Height="23" Margin="760,96,0,0" TextWrapping="Wrap" TextChanged="ValueBuyLimitEntered_TextChanged" Text="" VerticalAlignment="Top" Width="130" Visibility="Visible"/>
                        <Button x:Name="SkipBuyLimit" Content="remove buy limit" Click ="SkipBuyLimit_Click" FontSize="18" Margin="760,0,0,30" HorizontalAlignment="Left" Width="160" Height="50" VerticalAlignment="Bottom" Visibility="Hidden"/>
                        <Button x:Name="SetBuyLimit" Content="set buy limit" Margin="760,0,0,29" Click="SetBuyLimit_Click" FontSize="18" Visibility="Hidden" HorizontalAlignment="Left" Width="160" Height="52" VerticalAlignment="Bottom"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Controls:MetroContentControl>
</Controls:MetroWindow>
